---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import HeroSection from "../components/HeroSection";
import TrustStrip from "../components/TrustStrip";
import HowItWorks from "../components/HowItWorks";
import SocialProof from "../components/SocialProof";
import UseCases from "../components/UseCases";
import AIQuality from "../components/AIQuality";
import PricingSection from "../components/PricingSection";
import Footer from "../components/Footer";

const appSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Summit AI Notes",
  alternateName: ["SummitAI", "Summit AI", "Summit Notes"],
  operatingSystem: "macOS",
  applicationCategory: "BusinessApplication",
  description:
    "No bots joining your calls. No data leaving your device. Summit records every meeting locally on your Mac — transcription, summaries, action items. Private by design.",
  url: "https://summitnotes.app",
  downloadUrl: "https://apps.apple.com/app/summit-ai-notes/id6754717420",
  softwareVersion: "1.0",
  offers: [
    {
      "@type": "Offer",
      price: "12.99",
      priceCurrency: "USD",
      description: "Monthly subscription with all features",
    },
    {
      "@type": "Offer",
      price: "89.99",
      priceCurrency: "USD",
      description: "Yearly subscription — save 42%",
    },
    {
      "@type": "Offer",
      price: "149.99",
      priceCurrency: "USD",
      description: "Lifetime one-time purchase",
    },
  ],
  featureList: [
    "Record both sides of any call",
    "Local AI transcription",
    "AI-powered summaries and action items",
    "100% on-device processing",
    "Works with Zoom, Teams, Meet, and any app",
    "99+ languages supported",
    "Search through past meetings",
  ],
  screenshot: "https://summitnotes.app/og-image.png",
};
---

<Layout
  title="Summit AI Notes - AI Meeting Notes for Consultants"
  description="No bots joining your calls. No data leaving your device. Summit records every meeting locally on your Mac — transcription, summaries, action items. Private by design."
  schema={appSchema}
>
  <div class="min-h-screen">
    <Navigation />
    <div id="hero">
      <HeroSection client:load />
    </div>
    <TrustStrip client:load />
    <div id="features">
      <SocialProof client:load />
    </div>
    <div id="use-cases">
      <UseCases client:load />
    </div>
    <AIQuality client:load />
    <div id="how-it-works">
      <HowItWorks client:load />
    </div>
    <PricingSection client:load />
    <Footer client:load />
  </div>
</Layout>
